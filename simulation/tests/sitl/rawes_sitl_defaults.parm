# rawes_sitl_defaults.parm — SITL boot-time parameter defaults for RAWES stack tests.
#
# Loaded via --add-param-file (combined with --wipe-eeprom) in _launch_sitl().
# These params become the boot defaults so setting them again via MAVLink is a
# no-op (value unchanged) — prevents EKF reinit that would delay GPS fusion.
# Loading as boot defaults (not post-boot MAVLink sets) avoids the EKF reinit
# that would otherwise delay GPS fusion past the kinematic window.
#
# EK3_SRC1_YAW=8 (GPS velocity yaw): EKF derives heading from GPS velocity direction.
# Compass is disabled (COMPASS_USE=0) because:
#   1. The GB4008 motor will swamp the magnetometer on real hardware.
#   2. SITL has 3 synthetic compasses; with COMPASS_USE=1 the EKF3 compass selector
#      cycles through all three every 10 s (magFailTimeLimit_ms) when innovations fail,
#      blocking GPS fusion indefinitely.
# GPS velocity yaw requires the vehicle to be moving (~0.5 m/s minimum).  During the
# kinematic phase vel = orbital speed (0.96 m/s), so heading is well-defined.

# ACRO rate controller I-term limits.
# Lua sends rate commands starting 3 s before kinematic exits (FLIGHT_SETTLE_MS=62s,
# kinematic exits at 65s).  During that window kinematic locks R=R0 and omega=0, so
# ArduPilot sees rate_error = setpoint - 0 != 0 and integrates the I-term.  At
# kinematic exit the accumulated I-term discharges as a large torque impulse, tumbling
# the hub.  Setting IMAX=0 disables I-term accumulation; P-term alone drives corrections.
ATC_RAT_RLL_IMAX  0    # roll  rate I-term limit = 0 → no I windup during kinematic
ATC_RAT_PIT_IMAX  0    # pitch rate I-term limit = 0 → no I windup during kinematic
ATC_RAT_YAW_IMAX  0    # yaw   rate I-term limit = 0 → no I windup during kinematic

EK3_IMU_MASK    1      # bit 0 only = IMU0 only = single EKF3 core (eliminates Roll/Pitch inconsistency)
EK3_SRC1_YAW    8      # 8=GPS velocity yaw: heading from GPS velocity direction
                       # R_orb yaw is built with North x body_z → yaw = 90° = GPS vel heading.
                       # Zero heading gap: accel/gyro body frame consistent with EKF yaw.
EK3_MAG_CAL     0      # 0=Never
EK3_GPS_CHECK   0      # skip HDOP/speed-accuracy/min-sat checks (SITL JSON GPS has no quality fields)
EK3_POS_I_GATE  50     # position innovation gate (sigma) — default 5; widened to prevent GPS glitch at extreme attitude
EK3_VEL_I_GATE  50     # velocity innovation gate (sigma) — default 5; widened to prevent GPS glitch at extreme attitude
COMPASS_USE     0      # disable compass: GB4008 motor swamps magnetometer on hardware;
COMPASS_ENABLE  0      #   SITL synthetic compasses unnecessary when using GPS vel yaw
SCR_ENABLE      1      # enable Lua scripting on first boot (required for acro_armed_lua)
# Collective servo range: full 1000-2000 us so Lua's ch3 encoding maps 1:1 to servos.
# copter-heli.parm defaults to H_COL_MIN=1250/H_COL_MAX=1750 (0.5x gain).
# With 0.5x gain, Lua ch3=1945 (COL_CRUISE) -> servo=1718 -> col_rad=0.0437 (T_est=0).
# With full range, Lua ch3=1945 -> servo=1945 -> collective_norm=0.89 -> col_rad=0.089.
# 12% above Lua COL_CRUISE_RAD=0.079 but produces positive thrust; VZ controller equilibrates.
H_COL_MIN       1000   # minimum collective servo output (us) -- full range
H_COL_MAX       2000   # maximum collective servo output (us) -- full range
H_RSC_MODE      1      # 1=Passthrough: no main rotor motor (autorotation only).
                       # With mode 1, servo8 = RC8 immediately — no spool-up ramp.
                       # Motor interlock HIGH (RC8=2000) → servo8=2000 → THROTTLE_UNLIMITED
                       # immediately → land_complete can clear without waiting for runup.
