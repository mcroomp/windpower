# rawes_sitl_defaults.parm — SITL boot-time parameter defaults for RAWES stack tests.
#
# Loaded via --add-param-file (combined with --wipe-eeprom) in _launch_sitl().
# These params become the boot defaults so setting them again via MAVLink is a
# no-op (value unchanged) — prevents EKF reinit that would delay GPS fusion.
#
# EK3_SRC1_YAW=2 (GPS dual-antenna yaw): heading from the RELPOSNED baseline
# vector between two F9P antennas 50 cm apart on the rotor disk.  Yaw is known
# from the first GPS fix — no motion, no EKFGSF rotation needed.
#
# GPS_AUTO_CONFIG=0: required for SITL RELPOSNED stream.  Without it ArduPilot
# tries to reconfigure the UBLOX chips over serial and corrupts the stream.
#
# Compass is disabled (COMPASS_USE=0) because:
#   1. The GB4008 motor swamps the magnetometer on real hardware.
#   2. SITL has 3 synthetic compasses; with dual GPS yaw they are not needed.

# ACRO rate controller I-term limits.
# Zero I-term prevents windup during the kinematic phase.
ATC_RAT_RLL_IMAX  0    # roll  rate I-term limit = 0 -> no I windup during kinematic
ATC_RAT_PIT_IMAX  0    # pitch rate I-term limit = 0 -> no I windup during kinematic
ATC_RAT_YAW_IMAX  0    # yaw   rate I-term limit = 0 -> no I windup during kinematic

EK3_IMU_MASK    1      # bit 0 only = IMU0 only = single EKF3 core (no Roll/Pitch inconsistency)
EK3_SRC1_YAW    2      # 2=GPS dual-antenna yaw (RELPOSNED from F9P moving baseline)
EK3_MAG_CAL     0      # 0=Never
EK3_GPS_CHECK   0      # skip HDOP/speed-accuracy/min-sat checks (SITL JSON GPS has no quality fields)
EK3_POS_I_GATE  50     # position innovation gate (sigma) — widened for extreme attitude
EK3_VEL_I_GATE  50     # velocity innovation gate (sigma) — widened for extreme attitude

# Dual GPS moving-baseline heading (F9P GPS-for-yaw)
GPS_AUTO_CONFIG  0     # disable GPS auto-config: required in SITL to preserve RELPOSNED stream
GPS1_TYPE        17    # F9P RTK_BASE: sends RTCM corrections to GPS2
GPS2_TYPE        18    # F9P RTK_ROVER: receives RTCM, outputs RELPOSNED heading
GPS1_POS_X       0.25  # GPS1 lever arm: +25 cm along body X from hub centre
GPS2_POS_X      -0.25  # GPS2 lever arm: -25 cm along body X from hub centre
SIM_GPS2_DISABLE 0     # enable second SITL GPS instance
SIM_GPS2_TYPE    1     # GPS2 sim type = UBLOX (generates RELPOSNED when SIM_GPS2_HDG=1)
SIM_GPS2_HDG     1     # generate RELPOSNED heading on GPS2 (the rover instance)
SIM_GPS_POS_X    0.25  # GPS1 simulated body-frame X offset: +25 cm
SIM_GPS2_POS_X  -0.25  # GPS2 simulated body-frame X offset: -25 cm

COMPASS_USE     0      # disable compass: GB4008 motor swamps magnetometer on hardware
COMPASS_ENABLE  0      # disable all SITL synthetic compasses
COMPASS_USE2    0      # disable compass instance 2
COMPASS_USE3    0      # disable compass instance 3
SCR_ENABLE      1      # enable Lua scripting on first boot (required for acro_armed_lua)

# Collective servo range: full 1000-2000 us so Lua's ch3 encoding maps 1:1 to servos.
# copter-heli.parm defaults to H_COL_MIN=1250/H_COL_MAX=1750 (0.5x gain).
# With full range, Lua ch3=1945 -> servo=1945 -> collective_norm=0.89 -> col_rad=0.089.
H_COL_MIN       1000   # minimum collective servo output (us) -- full range
H_COL_MAX       2000   # maximum collective servo output (us) -- full range
H_RSC_MODE      1      # 1=Passthrough: no main rotor motor (autorotation only).
                       # Motor interlock HIGH (RC8=2000) -> THROTTLE_UNLIMITED immediately.
