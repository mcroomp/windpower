##############################################################################
# rawes.set — MBDyn parameter set file for RAWES simulation
# Included by rotor.mbd via: include: "rawes.set";
#
# All physical constants for a 4-blade tethered autorotating rotor kite.
# Parameters sourced from CLAUDE.md and Weyel 2025 thesis (adapted for
# 4-blade, 2m-blade geometry).
##############################################################################

# --------------------------------------------------------------------------
# Simulation timing
# --------------------------------------------------------------------------
set: real DT         = 2.5e-3;      # time step [s] → 400 Hz
set: real T_FINAL    = 300.0;       # final simulation time [s]
set: real T_RAMP     = 5.0;         # aero spin-up ramp duration [s]

# --------------------------------------------------------------------------
# Physical constants
# --------------------------------------------------------------------------
set: real G          = 9.81;        # gravitational acceleration [m/s²]
set: real RHO        = 1.22;        # air density [kg/m³]

# --------------------------------------------------------------------------
# Initial conditions
# --------------------------------------------------------------------------
set: real X0         = 0.0;         # initial hub X (East) [m]
set: real Y0         = 0.0;         # initial hub Y (North) [m]
set: real Z0         = 50.0;        # initial hub altitude [m]
set: real OMEGA0     = 28.0;        # initial rotor spin rate [rad/s] (λ=7 at 10m/s)
set: real WIND_X     = 10.0;        # initial wind speed East [m/s]
set: real WIND_Y     = 0.0;         # initial wind speed North [m/s]
set: real WIND_Z     = 0.0;         # initial wind speed Up [m/s]

# --------------------------------------------------------------------------
# Rotor geometry
# --------------------------------------------------------------------------
set: integer N_BLADES  = 4;         # number of blades
set: real BLADE_LEN    = 2.0;       # blade span (root-to-tip) [m]
set: real R_ROOT       = 0.5;       # blade root radius [m]
set: real R_TIP        = 2.5;       # blade tip radius [m]  (R_ROOT + BLADE_LEN)
set: real CHORD        = 0.15;      # blade chord [m]
set: real DISK_AREA    = 19.635;    # π * R_TIP² [m²]  (π * 2.5²)

# --------------------------------------------------------------------------
# Rotor mass / inertia
# --------------------------------------------------------------------------
set: real M_ROTOR      = 5.0;       # total rotor mass [kg]
set: real Ixx          = 5.0;       # rotor Ixx = Iyy [kg·m²]
set: real Iyy          = 5.0;       # rotor Iyy [kg·m²]
set: real Izz          = 10.0;      # rotor Izz (spin axis) [kg·m²]
set: real WEIGHT       = 49.05;     # M_ROTOR * G [N]  — used for initial force

# --------------------------------------------------------------------------
# Tether
# NOTE: tether force is computed in mediator.py (Python), not in MBDyn.
#       The rod joint has been removed so that the tether can be modelled
#       as tension-only (a real rope cannot push).
#       Physical tether: Dyneema SK75 1.9 mm braided, EA ≈ 250 kN.
#       See mediator.py TetherModel for the full parameter set.
# --------------------------------------------------------------------------

# --------------------------------------------------------------------------
# Aerodynamic coefficients (SG6042, from Weyel 2025)
# --------------------------------------------------------------------------
set: real CL0          = 0.11;      # zero-AoA lift coefficient
set: real CL_ALPHA     = 0.87;      # lift curve slope [1/rad]
set: real CD0          = 0.007;     # zero-AoA drag coefficient
set: real CD_ALPHA     = 0.00013;   # drag polar coefficient [1/rad²]
set: real CM0          = -0.08;     # zero-AoA pitching moment coefficient
set: real CM_ALPHA     = 0.002;     # pitching moment slope [1/rad]
set: real CM_GAMMA     = -0.5;      # pitching moment due to flap deflection [1/rad]

# --------------------------------------------------------------------------
# Swashplate / control geometry
# --------------------------------------------------------------------------
set: real PITCH_GAIN   = 0.3;       # max swashplate tilt [rad] (normalized → rad)
set: real COLL_MAX     = 0.35;      # max collective blade pitch [rad]
set: real K_CYC        = 0.4;       # cyclic moment gain (dimensionless)

# --------------------------------------------------------------------------
# Node labels
# --------------------------------------------------------------------------
set: integer HUB_NODE    = 1;
set: integer GROUND_NODE = 2;

# --------------------------------------------------------------------------
# Body / element labels
# --------------------------------------------------------------------------
set: integer HUB_BODY    = 1;
set: integer GROUND_CLAMP = 1;
set: integer FORCE_ELEM  = 1;
set: integer COUPLE_ELEM = 2;

# --------------------------------------------------------------------------
# File driver / stream labels
# --------------------------------------------------------------------------
set: integer FORCES_DRIVER = 1;    # stream driver for incoming forces
set: integer STATE_OUTPUT  = 1;    # stream output for hub state
